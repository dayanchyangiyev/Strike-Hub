<!DOCTYPE html>
<html lang="ro">
<%- include('../fragments/head') %>

    <body id="sus">
        <%- include('../fragments/header') %>

            <main class="error-container">
                <article class="error-card">
                    <h2 class="error-id">
                        Eroare <%= identificator %> <i class="fa-solid fa-triangle-exclamation"></i>
                    </h2>
                    <h3 class="error-title">
                        <%= titlu %>
                    </h3>

                    <% if (typeof image !=='undefined' && image) { %>
                        <img src="<%= image %>" alt="Imagine de eroare" class="error-image">
                    <% } %>

                    <p class="error-text">
                        <%= text %>
                    </p>

                    <div class="error-actions">
                        <a href="/" class="btn-home">
                            <i class="fa-solid fa-house"></i> Întoarce-te la Bază
                        </a>
                    </div>
                </article>
            </main>

            <%- include('../fragments/footer') %>
    </body>

</html>